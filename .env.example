# ─────────────────────────────────────────────────────────────────────────────
# DataScout Environment Variables
# Copy this file to .env and configure your values
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL
POSTGRES_USER=datascout
POSTGRES_PASSWORD=changeme_in_production
POSTGRES_DB=datascout

# ChromaDB Authentication
CHROMA_AUTH_TOKEN=changeme_in_production

# CUDA / GPU Settings
CUDA_VISIBLE_DEVICES=0

# Application Settings
DEBUG=false

# Local demo defaults: keep uploads fast and avoid heavy model downloads.
# Set to true only when you explicitly want BART / semantic embeddings.
DATASCOUT_HEAVY_ML=false
DATASCOUT_SEMANTIC_SEARCH=false
DATASCOUT_GENERATE_DASHBOARD=false
